{
  "name": "@browserstack/ai-evals",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action that runs TestOps evals and posts PR comments.",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild --platform=node --bundle src/main.ts --outfile=dist/index.js --minify --sourcemap --target=es2020",
    "lint": "eslint src test --ext .ts",
    "test": "tsc --noEmit -p tsconfig.json && npm run lint && nyc mocha --require ts-node/register 'test/**/*.test.ts'"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm test && npm run build && git add dist/"
    }
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@browserstack/ai-sdk": "1.0.0-beta.3"
  },
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/sinon": "^17.0.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "chai": "^4.3.10",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "husky": "^4.2.5",
    "mocha": "^10.2.0",
    "nyc": "^15.1.0",
    "sinon": "^17.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
